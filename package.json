{
  "name": "called-it",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Called It: pay-to-scan trader calls, scorecards, and leaderboard built on MPP.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api": "bun run apps/api/src/server.ts",
    "web": "bunx next dev apps/web -p ${WEB_PORT:-3002}",
    "db:migrate": "bun run packages/db/src/migrate.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@called-it/core": "workspace:*",
    "@called-it/db": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "lucide-react": "^1.20.0",
    "mppx": "latest",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "viem": "^2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5"
  }
}
