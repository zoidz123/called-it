# Required for the API and database migrations.
DATABASE_URL=

# Required for new scans.
OPENAI_API_KEY=
TWITTERAPI_IO_API_KEYS=

# Required for production web builds and recommended locally.
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3002

# Required in production to restrict browser access to the API.
CORS_ORIGIN=

# Optional local ports and scan settings.
API_PORT=3001
WEB_PORT=3002
TWITTER_LOOKBACK_DAYS=365
SCAN_WORKER_ENABLED=true
